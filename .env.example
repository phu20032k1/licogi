# Bắt buộc: PostgreSQL/Neon/Supabase/Railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Nên đổi khi seed dữ liệu/tài khoản demo
PRISMA_SEED_PASSWORD="CHANGE_ME_WITH_A_STRONG_PASSWORD"

# Bắt buộc nếu sử dụng chức năng upload trên Vercel
S3_ENDPOINT="https://your-s3-compatible-endpoint"
S3_REGION="us-east-1"
S3_BUCKET="licogi-os"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="https://your-public-file-domain"
MAX_UPLOAD_BYTES="50000000"

# Tùy chọn
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
AUTODESK_CLIENT_ID=""
AUTODESK_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
